% ============================================================================
% onemath.sty — shared style for the One Math Book project
%
% All packages, theorem environments and macros live here. Chapter files must
% not load packages or define macros: if you need something new, add it here
% and document it in CONTRIBUTING.md.
%
% Language: set \booklang before loading (default en). UI strings and part
% titles live in styles/lang/<lang>.tex. Chapter bodies for non-English
% languages live under parts/<year>/<lang>/ (see \ominput / \ominputsol).
% ============================================================================
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{onemath}[2026/07/11 v0.2 One Math Book common style]

% ----------------------------------------------------------------------------
% Language selection (default: English)
% ----------------------------------------------------------------------------
\providecommand{\booklang}{en}

% ----------------------------------------------------------------------------
% Core packages
% ----------------------------------------------------------------------------
\RequirePackage[T1]{fontenc}
\RequirePackage[utf8]{inputenc}
\RequirePackage{lmodern}
\RequirePackage{microtype}
\RequirePackage[a4paper,inner=2.2cm,outer=2.2cm,top=2.4cm,bottom=2.6cm,headheight=14pt]{geometry}

% babel: only for non-English editions (keeps English builds unchanged).
% Compare expanded token lists so \newcommand{\booklang}{fr} matches.
% Load language babel only when the .ldf is installed; UI strings still
% come from styles/lang/<lang>.tex either way.
\edef\om@booklang@exp{\booklang}%
\def\om@lang@fr{fr}%
\def\om@lang@nl{nl}%
\ifx\om@booklang@exp\om@lang@fr
  \IfFileExists{french.ldf}{%
    \RequirePackage[french]{babel}%
  }{%
    \PackageWarning{onemath}{%
      french.ldf not found; building French without babel.
      Install texlive-lang-french for hyphenation and spacing}%
  }%
\fi
\ifx\om@booklang@exp\om@lang@nl
  \IfFileExists{dutch.ldf}{%
    \RequirePackage[dutch]{babel}%
  }{%
    \PackageWarning{onemath}{%
      dutch.ldf not found; building Dutch without babel.
      Install texlive-lang-european (or babel-dutch) for hyphenation}%
  }%
\fi

\RequirePackage{amsmath}
\RequirePackage{amssymb}
\RequirePackage{amsthm}
\RequirePackage{mathtools}
\RequirePackage{enumitem}
\RequirePackage{graphicx}
\RequirePackage{tikz}
\RequirePackage{pgfplots}
\pgfplotsset{compat=1.18}
\usepgfplotslibrary{fillbetween}
\usetikzlibrary{arrows.meta,calc,angles,quotes,patterns}
% Unbreakable in-text figure block: keeps a picture and its caption line
% on the same page. Use in place of "center" around tikzpicture figures.
\newenvironment{omfigure}
  {\par\medskip\noindent\begin{minipage}{\linewidth}\centering}
  {\end{minipage}\par\medskip}

% Shared axis style for in-text figures: use with \begin{axis}[omaxis, ...].
\pgfplotsset{
  omaxis/.style={
    axis lines=middle,
    tick label style={font=\small},
    label style={font=\small},
    xlabel={$x$}, ylabel={$y$},
    xlabel style={below right}, ylabel style={above left},
    samples=100,
  },
}
\RequirePackage[most]{tcolorbox}
\RequirePackage{imakeidx}
\makeindex[intoc]
\RequirePackage[colorlinks=true,linkcolor=blue!50!black,urlcolor=blue!50!black]{hyperref}
\RequirePackage[nameinlink,capitalize]{cleveref}

\setlist[enumerate]{itemsep=1pt,topsep=3pt}
\setlist[itemize]{itemsep=1pt,topsep=3pt}

% ----------------------------------------------------------------------------
% Language strings (theorem names, cover, part titles, …)
% ----------------------------------------------------------------------------
\input{styles/lang/\booklang.tex}

% Lookup structural string defined in the lang file via \@namedef{omstr@KEY}.
\newcommand{\omstr}[1]{\csname omstr@#1\endcsname}

% ----------------------------------------------------------------------------
% Language-aware content paths
%
% \ominput{grade-1}{01-counting-to-20}
%   → parts/grade-1/<lang>/01-counting-to-20.tex if it exists
%   → else parts/grade-1/01-counting-to-20.tex (English canonical)
%
% \ominputsol{grade-1}{01-counting-to-20} — same rule under solutions/
% ----------------------------------------------------------------------------
\newcommand{\ominput}[2]{%
  \IfFileExists{parts/#1/\booklang/#2.tex}%
    {\input{parts/#1/\booklang/#2}}%
    {\input{parts/#1/#2}}%
}
\newcommand{\ominputsol}[2]{%
  \IfFileExists{parts/#1/solutions/\booklang/#2.tex}%
    {\input{parts/#1/solutions/\booklang/#2}}%
    {\input{parts/#1/solutions/#2}}%
}

% ----------------------------------------------------------------------------
% Page layout details
% ----------------------------------------------------------------------------
% Chapters/parts open on any page (class option "openany" in main.tex);
% also drop the forced blank page at the front/back matter boundaries.
\patchcmd{\mainmatter}{\cleardoublepage}{\clearpage}{}{}
\patchcmd{\backmatter}{\cleardoublepage}{\clearpage}{}{}

% The book has more than 99 chapters: widen the number boxes in the table
% of contents so three-digit chapter numbers (and their section numbers,
% like "102.4") do not run into the titles.
\patchcmd{\l@chapter}{1.5em}{2.3em}{}{}
\renewcommand*\l@section{\@dottedtocline{1}{2.3em}{3.2em}}

% Running headers: small italics, no uppercase, so long chapter titles fit.
\RequirePackage{fancyhdr}
\pagestyle{fancy}
\fancyhf{}
\fancyhead[LE]{\thepage\quad{\small\itshape\nouppercase{\leftmark}}}
\fancyhead[RO]{{\small\itshape\nouppercase{\rightmark}}\quad\thepage}
\renewcommand{\headrulewidth}{0.2pt}

% ----------------------------------------------------------------------------
% Colors (sober)
% ----------------------------------------------------------------------------
\definecolor{omDef}{RGB}{0,84,147}      % definitions: blue
\definecolor{omThm}{RGB}{150,20,30}     % theorems: dark red
\definecolor{omProp}{RGB}{190,90,20}    % propositions/lemmas/corollaries: orange
\definecolor{omMeth}{RGB}{20,110,60}    % methods: green
\definecolor{omExo}{RGB}{80,80,80}      % exercises: gray

% ----------------------------------------------------------------------------
% One Course brand (title page and shared product theme — see THEME.md)
% ----------------------------------------------------------------------------
\definecolor{ocMint}{HTML}{06D6A0}      % brand quad: mint
\definecolor{ocYellow}{HTML}{FFD166}    % brand quad: yellow
\definecolor{ocRed}{HTML}{EF476F}       % brand quad: red
\definecolor{ocBlue}{HTML}{118AB2}      % brand quad: blue
\definecolor{ocInk}{HTML}{1F2430}       % near-black text on light grounds
\colorlet{ocPaleBlue}{ocBlue!14!white}  % pale blue-gray ground / band tint
\colorlet{ocDarkBlue}{ocBlue!80!black}  % titles and the "1" of the rosette

% \ocQuadLine{x0}{x1}{y}{h}: horizontal bar from x0 to x1 at height y,
% thickness h, split into four equal segments in the brand quad colors.
% Coordinates in the surrounding tikzpicture's units (cm on the cover).
\newcommand{\ocQuadLine}[4]{%
  \pgfmathsetmacro{\ocqSeg}{(#2-#1)/4}%
  \fill[ocMint]   (#1,#3) rectangle ({#1+\ocqSeg},{#3+#4});
  \fill[ocYellow] ({#1+\ocqSeg},#3) rectangle ({#1+2*\ocqSeg},{#3+#4});
  \fill[ocRed]    ({#1+2*\ocqSeg},#3) rectangle ({#1+3*\ocqSeg},{#3+#4});
  \fill[ocBlue]   ({#1+3*\ocqSeg},#3) rectangle (#2,{#3+#4});}

% \ocRosette{x}{y}{R}{pt}: the One Course rosette logo centered at (x,y),
% radius R cm, with the "1" set at pt points. Four quadrant wedges (mint on
% top, yellow left, red bottom, blue right) separated by white diagonals,
% around a white core circle. The diagonal line width scales with R.
\newcommand{\ocRosette}[4]{%
  \pgfmathsetmacro{\ocrCut}{#3*1.02}%
  \pgfmathsetlengthmacro{\ocrLW}{#3*1.4}%
  \fill[ocMint]   (#1,#2) -- ([shift={(#1,#2)}]45:#3)
    arc[start angle=45, end angle=135, radius=#3] -- cycle;
  \fill[ocYellow] (#1,#2) -- ([shift={(#1,#2)}]135:#3)
    arc[start angle=135, end angle=225, radius=#3] -- cycle;
  \fill[ocRed]    (#1,#2) -- ([shift={(#1,#2)}]225:#3)
    arc[start angle=225, end angle=315, radius=#3] -- cycle;
  \fill[ocBlue]   (#1,#2) -- ([shift={(#1,#2)}]315:#3)
    arc[start angle=315, end angle=405, radius=#3] -- cycle;
  \draw[white, line width=\ocrLW]
    ([shift={(#1,#2)}]45:\ocrCut) -- ([shift={(#1,#2)}]225:\ocrCut);
  \draw[white, line width=\ocrLW]
    ([shift={(#1,#2)}]135:\ocrCut) -- ([shift={(#1,#2)}]315:\ocrCut);
  \fill[white] (#1,#2) circle ({#3*0.58});
  \node[text=ocDarkBlue, font=\fontsize{#4}{#4}\selectfont\bfseries]
    at (#1,#2) {1};}

% ----------------------------------------------------------------------------
% Theorem environments
%
% amsthm owns numbering, labels and cleveref support; tcolorbox only
% decorates. All statement environments share one counter, numbered within
% chapter. Exercises have their own counter.
%
% Titles come from styles/lang/<lang>.tex (\omnameDefinition, …).
% Usage: \begin{theorem}[Monotone convergence]\label{thm:tle:seq:monotone}
% ----------------------------------------------------------------------------
\theoremstyle{definition}                 % upright body text, bold heading
\newtheorem{definition}{\omnameDefinition}[chapter]
\newtheorem{theorem}[definition]{\omnameTheorem}
\newtheorem{proposition}[definition]{\omnameProposition}
\newtheorem{lemma}[definition]{\omnameLemma}
\newtheorem{corollary}[definition]{\omnameCorollary}
\newtheorem{method}[definition]{\omnameMethod}
\newtheorem{example}[definition]{\omnameExample}
\newtheorem{notation}[definition]{\omnameNotation}
\theoremstyle{remark}
\newtheorem{remark}[definition]{\omnameRemark}

\newtheorem{exercise}{\omnameExercise}[chapter]

% Decoration: colored left rule + light background.
% "lines before break" forces boxes with no room for their first lines to
% move to the next page instead of attempting a zero-height first part,
% which would silently discard any \label written there. (Raised from 3
% to 5 after a recurrence: a box starting very close to the page bottom
% could still produce a discarded zero-height first part.)
\newcommand{\omdecorate}[2]{%
  \tcolorboxenvironment{#1}{%
    enhanced jigsaw, breakable, frame hidden,
    boxrule=0pt, sharp corners,
    borderline west={2pt}{0pt}{#2},
    left=8pt, right=4pt, top=4pt, bottom=4pt,
    before skip=10pt, after skip=10pt,
    lines before break=5,
    colback=#2!4!white}%
}
\omdecorate{definition}{omDef}
\omdecorate{theorem}{omThm}
\omdecorate{proposition}{omProp}
\omdecorate{lemma}{omProp}
\omdecorate{corollary}{omProp}
\omdecorate{method}{omMeth}
\omdecorate{exercise}{omExo}

% Results stated without proof
\newcommand{\admitted}{\begin{proof}[\omnameProof]\emph{\omadmittedtext}\end{proof}}

% cleveref names
\crefname{exercise}{\omnameExercise}{\omnameExercises}
\Crefname{exercise}{\omnameExercise}{\omnameExercises}

% ----------------------------------------------------------------------------
% Solutions appendix
% Usage: \begin{solution}{exo:tle:seq:1} ... \end{solution}
% Prints "Solution of Exercise <n> (page <p>)." / French equivalent.
% ----------------------------------------------------------------------------
\newenvironment{solution}[1]{%
  \par\medskip\noindent\textbf{\omsolutionof~\cref{#1}} (\ompage~\pageref{#1}).\par\nopagebreak\smallskip
  \noindent\ignorespaces
}{\par\medskip}

% ----------------------------------------------------------------------------
% Math macros
% ----------------------------------------------------------------------------
% Number sets
\newcommand{\N}{\mathbb{N}}
\newcommand{\Z}{\mathbb{Z}}
\newcommand{\Q}{\mathbb{Q}}
\newcommand{\R}{\mathbb{R}}
\newcommand{\C}{\mathbb{C}}

% Delimiters
\DeclarePairedDelimiter{\abs}{\lvert}{\rvert}
\DeclarePairedDelimiter{\norm}{\lVert}{\rVert}
\DeclarePairedDelimiter{\floor}{\lfloor}{\rfloor}

% Intervals (international convention): \intcc{a}{b} = [a, b], \intoo = (a, b)
\newcommand{\intcc}[2]{\left[#1,\,#2\right]}
\newcommand{\intoo}[2]{\left(#1,\,#2\right)}
\newcommand{\intco}[2]{\left[#1,\,#2\right)}
\newcommand{\intoc}[2]{\left(#1,\,#2\right]}
% Integer interval \intint{a}{b} = [[a, b]] = {a, a+1, ..., b}
\newcommand{\intint}[2]{[\![#1,\,#2]\!]}
% Triple bar (operator norm) |||u|||
\newcommand{\vertiii}[1]{{\left\vert\kern-0.3ex\left\vert\kern-0.3ex\left\vert
  #1 \right\vert\kern-0.3ex\right\vert\kern-0.3ex\right\vert}}

% Calculus
\newcommand{\dd}{\mathop{}\!\mathrm{d}}
\newcommand{\eu}{\mathrm{e}}
\newcommand{\iu}{\mathrm{i}}

% Vectors and geometry
\newcommand{\vect}[1]{\overrightarrow{#1}}
\newcommand{\scal}[2]{\vect{#1}\cdot\vect{#2}}

% Complex numbers
\newcommand{\conj}[1]{\overline{#1}}
\DeclareMathOperator{\Rea}{Re}
\DeclareMathOperator{\Ima}{Im}
\DeclareMathOperator{\Arg}{arg}

% Probability
\renewcommand{\P}{\mathbb{P}}
\newcommand{\E}{\mathbb{E}}
\newcommand{\V}{\mathbb{V}}
\newcommand{\pcond}[2]{\P_{#1}\!\left(#2\right)}

% Arithmetic
\DeclareMathOperator{\lcm}{lcm}

% Misc: \st is defined in styles/lang/<lang>.tex
